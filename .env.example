# ── Pipeline settings ─────────────────────────────────────────────
# How often to run (minutes). 720 = every 12 hours.
PIPELINE_INTERVAL=720

# Concurrent workers for product listing pages
PIPELINE_WORKERS=16

# Concurrent workers for product detail pages
PIPELINE_DETAIL_WORKERS=16

# Retries per site before marking it as failed (0 = no retry)
PIPELINE_SITE_RETRIES=2

# Seconds to wait between retries
PIPELINE_RETRY_DELAY=30

# Per-site scraping timeout in seconds (default 1800 = 30 min)
PIPELINE_SITE_TIMEOUT=1800

# ── Optional overrides ────────────────────────────────────────────
# Set to "1" to force --no-sandbox even outside Docker
# DOCKER_CONTAINER=1
